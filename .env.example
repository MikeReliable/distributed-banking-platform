# Internal service authentication
INTERNAL_CLIENT_TRANSFER_SERVICE_SECRET=transfer-service-secret

# JWT signing (auth-service private key)
AUTH_JWT_KEYSTORE_PASSWORD=auth-jwt-password-example
AUTH_JWT_KEY_ALIAS=auth-jwt

# TLS for local HTTPS between services
SHARED_SSL_KEYSTORE_PASSWORD=shared-password-example
TRUSTSTORE_PASSWORD=truststore-password-example

# Database passwords per service
DB_AUTH_PASSWORD=auth
DB_CARD_PASSWORD=card
DB_TRANSFER_PASSWORD=transfer
DB_USERDB_PASSWORD=user

# Rate limits for auth endpoints
AUTH_RATE_LIMIT_LOGIN_MAX_REQUESTS=20
AUTH_RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_TOKEN_MAX_REQUESTS=40
AUTH_RATE_LIMIT_TOKEN_WINDOW_SECONDS=60

# JWT issuer/audience for token issuing and validation
AUTH_JWT_ISSUER=auth-service
AUTH_JWT_AUDIENCE_USER=bank-rest-api
AUTH_JWT_AUDIENCE_SERVICE=bank-rest-internal
GATEWAY_JWT_ACCEPTED_AUDIENCES=bank-rest-api
USER_JWT_ACCEPTED_AUDIENCES=bank-rest-api
CARD_JWT_ACCEPTED_AUDIENCES=bank-rest-api,bank-rest-internal
TRANSFER_JWT_ACCEPTED_AUDIENCES=bank-rest-api

# Optional if keystore is not in ./certs/auth-jwt.p12
# AUTH_JWT_KEYSTORE_PATH=/certs/auth-jwt.p12
